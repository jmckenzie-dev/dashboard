{
  "name": "ai-agent-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 35001",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 35001",
    "start": "node build/server.js",
    "start:https": "node scripts/server-https.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
